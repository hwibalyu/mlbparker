{
  "manifest_version": 3,
  "name": "엠팍커(MLBParker)",
  "version": "1.3.1",
  "description": "엠팍(MLBPark) 게시글 작성자의 정보를 사이드 패널에서 간편하게 확인하고 게시글 목록을 스캔합니다.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
    },
  "permissions": [
    "sidePanel",
    "tabs",
    "storage",
    "contextMenus",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess"
  ],
  "action": {},
  "host_permissions": [
    "https://mlbpark.donga.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mlbpark.donga.com/mp/b.php?*", 
        "https://mlbpark.donga.com/mp", 
        "https://mlbpark.donga.com/mp/"
      ],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
